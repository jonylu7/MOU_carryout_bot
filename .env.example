# ── 個人 / 聯絡資訊 ──────────────────────────────
# 此檔案含個人資料，請勿提交至版本控制。

# 申請人姓名
DEFAULT_APPLICANT=

# 本地資料夾根目錄（Dropbox 同步資料夾）
BASE_DIR=

# Google Drive 申請表 File ID
DRIVE_FILE_ID=

# Google 服務帳戶金鑰檔名（放在本專案資料夾內）
GOOGLE_SERVICE_ACCOUNT_KEY=

# Gmail 寄件帳號 & App Password
EMAIL_SENDER=
EMAIL_PASSWORD=

# HITL 審核通知收件人（協調人自己）
EMAIL_COORDINATOR=

# 財資中心信件收件人（測試時填自己；正式改為承辦人 email）
EMAIL_MOF_TO=

# 財資中心信件 CC（逗號分隔；留空則不 CC）
EMAIL_MOF_CC=
